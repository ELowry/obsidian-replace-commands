{
	"name": "obsidian-replace-commands",
	"version": "0.1.0",
	"description": "This Obsidian plugin allows you to write search/replace patterns to easily reuse on any selection/document.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"format": "prettier --write \"src/**/*.{ts,js,css}\"",
		"check-format": "prettier --check \"src/**/*.{ts,js,css}\"",
		"test": "vitest run"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.11.0",
		"esbuild": "0.25.5",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "^17.4.0",
		"jiti": "2.6.1",
		"prettier": "^3.8.1",
		"prettier-plugin-css-order": "^2.2.0",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
